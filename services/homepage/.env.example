# Homepage — API credentials for live widget integrations

# Jellyfin — generate at https://jellyfin.yourdomain.com > Dashboard > Advanced > API Keys
JELLYFIN_API_KEY=your_jellyfin_api_key_here

# Portainer — generate at https://portainer.yourdomain.com > User Settings > Access Tokens
# Use a static access token, NOT a password-based JWT
PORTAINER_API_KEY=your_portainer_access_token_here

# Uptime Kuma — admin credentials
UPTIME_KUMA_USER=matthewbeausoleil
UPTIME_KUMA_PASS=your_uptime_kuma_password_here

